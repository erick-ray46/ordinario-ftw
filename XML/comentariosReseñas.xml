<?xml version="1.0" encoding="UTF-8"?>
<!-- Definición DTD Interna para Comentarios y Reseñas -->
<!DOCTYPE resenas [
    <!ELEMENT resenas (resena+)>
    <!ELEMENT resena (autor, fecha, calificacion, comentario, sucursalVisitada)>
    <!ATTLIST resena id ID #REQUIRED>
    
    <!ELEMENT autor (#PCDATA)>
    <!ELEMENT fecha (#PCDATA)>
    <!ELEMENT calificacion (#PCDATA)>
    <!ELEMENT comentario (#PCDATA)>
    <!ELEMENT sucursalVisitada (#PCDATA)>
]>

<resenas>
